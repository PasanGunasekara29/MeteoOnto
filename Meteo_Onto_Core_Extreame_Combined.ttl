###  http://meteo_onto.org/meteo_core/ob1
meteo_core:ob1 rdf:type owl:NamedIndividual ,
                        meteo_core:Observation ;
               meteo_core:hasResult meteo_core:or1 .


###  http://meteo_onto.org/meteo_core/or1
meteo_core:or1 rdf:type owl:NamedIndividual ,
                        meteo_core:Result ;
               meteo_core:hasUnit meteo_core:Celsius ;
               meteo_core:isResultOf meteo_core:ob1 ;
               meteo_core:hasValue "6.2"^^xsd:float .


